apiVersion: descheduler/v1alpha2
kind: DeschedulerPolicy
profiles:
  - name: default
    pluginConfig:
      - name: ResourceDefragmentation
        args:
          imbalanceThreshold: 0.20      # |RII| above this marks a Node fragmented
          maxEvictions: 5               # Upper bound on evictions per pass
          usageMode: actual-ewma        # EWMA-smoothed runtime CPU and memory
    plugins:
      balance:
        enabled:
          - ResourceDefragmentation
