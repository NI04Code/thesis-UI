apiVersion: descheduler/v1alpha2
kind: DeschedulerPolicy
profiles:
  - name: default
    pluginConfig:
      - name: ResourceDefragmentationC2
        args:
          maxEvictions: 50
          consolidationThreshold: 0.40
          consolidationTarget: 0.90
          usageMode: requests
          namespaces:
            exclude:
              - kube-system
    plugins:
      balance:
        enabled:
          - ResourceDefragmentationC2
